{
  "@context": {
    "@vocab": "https://billingmind.io/ontology#",
    "stripe": "https://stripe.com/docs/api#"
  },
  "@graph": [
    {
      "@id": "billingmind:Customer",
      "@type": "owl:Class",
      "properties": ["email", "stripeCustomerId", "createdAt"],
      "relations": {
        "hasSubscription": "billingmind:Subscription",
        "hasPaymentMethod": "billingmind:PaymentMethod"
      }
    },
    {
      "@id": "billingmind:Subscription",
      "@type": "owl:Class",
      "properties": ["stripeSubscriptionId", "status", "planId", "currentPeriodEnd"],
      "relations": {
        "belongsTo": "billingmind:Customer",
        "hasPlan": "billingmind:Plan",
        "generatesInvoice": "billingmind:Invoice"
      },
      "statusValues": ["active", "past_due", "canceled", "incomplete", "trialing"]
    },
    {
      "@id": "billingmind:Invoice",
      "@type": "owl:Class",
      "properties": ["stripeInvoiceId", "amount", "currency", "status", "dueDate"],
      "relations": {
        "isPartOf": "billingmind:Subscription",
        "mayHaveRefund": "billingmind:Refund"
      }
    },
    {
      "@id": "billingmind:DunningCycle",
      "@type": "owl:Class",
      "properties": ["attemptNumber", "nextRetryAt", "strategy"],
      "relations": {
        "targets": "billingmind:Subscription",
        "triggeredBy": "billingmind:Invoice"
      }
    },
    {
      "@id": "billingmind:Refund",
      "@type": "owl:Class",
      "properties": ["amount", "reason", "stripeRefundId"],
      "relations": {
        "isPartOf": "billingmind:Invoice"
      }
    },
    {
      "@id": "billingmind:AgentTask",
      "@type": "owl:Class",
      "properties": ["taskId", "taskType", "priority", "payload", "targetAgent"],
      "taskTypes": [
        "subscription.create",
        "subscription.cancel",
        "subscription.upgrade",
        "payment.retry",
        "dunning.initiate",
        "support.respond",
        "audit.analyze"
      ]
    }
  ]
}
